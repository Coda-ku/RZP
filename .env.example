# Supabase Configuration
# Get these values from your Supabase project dashboard: https://app.supabase.com

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous public key (safe to expose in frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (KEEP SECRET - server-side only!)
# This should NEVER be exposed in the browser or committed to version control
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Next.js Environment
NODE_ENV=development

# Database (for local development)
# DATABASE_URL=your-local-database-url

# Application Configuration
# NEXT_PUBLIC_API_URL=http://localhost:3000
